<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/styles/main.css">
  </head>
  <body class="pending-page">
    <main class="pending-wrap">
      <p>Device</p>
      <p><code><%= deviceCode %></code></p>
      <% if (accessState === "pending_activation" && clientId) { %>
        <p>Client ID</p>
        <p><code><%= clientId %></code></p>
      <% } %>
      <p id="device-state-message"><%= message %></p>
      <p class="pending-note" id="device-state-note"><%= note || "" %></p>
    </main>
    <% if (shouldPoll) { %>
      <script>
        (async () => {
          const currentAccessState = <%- JSON.stringify(accessState || null) %>;
          const currentClientState = <%- JSON.stringify(clientState) %>;
          const approvedDeviceStatus = "approved";
          const deviceCode = <%- JSON.stringify(deviceCode) %>;
          const initialDeviceStatus = <%- JSON.stringify(deviceStatus || null) %>;
          const pollIntervalMs = <%- JSON.stringify(devicePollIntervalMs) %>;
          let isChecking = false;
          let currentDeviceStatus = initialDeviceStatus;
          let currentHasCurrentAuthentication = <%- JSON.stringify(Boolean(hasCurrentAuthentication)) %>;
          let currentHasValidSession = <%- JSON.stringify(Boolean(hasValidSession)) %>;
          let currentIsActivatable = <%- JSON.stringify(Boolean(isActivatable)) %>;
          let currentCanAttemptBootstrapAuth = <%- JSON.stringify(Boolean(canAttemptBootstrapAuth)) %>;
          let currentCanAttemptReauth = <%- JSON.stringify(Boolean(canAttemptReauth)) %>;
          let lastSeenAccessState = currentAccessState;
          let authRetryBlocked = false;
          const messageElement = document.getElementById("device-state-message");
          const noteElement = document.getElementById("device-state-note");

          function getScopedDeviceSecretKey(currentDeviceCode) {
            return `mydashmaster-device-secret:${currentDeviceCode}`;
          }

          function getLegacyDeviceSecretKey() {
            return "mydashmaster-device-secret";
          }

          function persistScopedDeviceSecret(currentDeviceCode, deviceSecret) {
            window.localStorage.setItem(
              getScopedDeviceSecretKey(currentDeviceCode),
              deviceSecret
            );
          }

          function generateDeviceSecret() {
            const bytes = new Uint8Array(32);
            window.crypto.getRandomValues(bytes);
            return Array.from(bytes, (byte) =>
              byte.toString(16).padStart(2, "0")
            ).join("");
          }

          function readDeviceSecretCandidate(currentDeviceCode) {
            const scopedDeviceSecret = window.localStorage.getItem(
              getScopedDeviceSecretKey(currentDeviceCode)
            );

            if (scopedDeviceSecret) {
              return {
                secret: scopedDeviceSecret,
                source: "scoped"
              };
            }

            const legacyDeviceSecret = window.localStorage.getItem(
              getLegacyDeviceSecretKey()
            );

            if (legacyDeviceSecret) {
              return {
                secret: legacyDeviceSecret,
                source: "legacy"
              };
            }

            const newDeviceSecret = generateDeviceSecret();
            persistScopedDeviceSecret(currentDeviceCode, newDeviceSecret);
            return {
              secret: newDeviceSecret,
              source: "new"
            };
          }

          async function requestBootstrap(deviceSecret) {
            const response = await window.fetch("/api/device/<%= deviceCode %>/auth", {
              body: JSON.stringify({ deviceSecret }),
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/json"
              },
              method: "POST"
            });
            let payload = null;

            try {
              payload = await response.json();
            } catch (error) {
              payload = null;
            }

            return {
              ok: response.ok,
              payload,
              status: response.status
            };
          }

          async function requestStatus() {
            const response = await window.fetch("/api/device/<%= deviceCode %>/status", {
              cache: "no-store",
              credentials: "same-origin"
            });

            return response.json();
          }

          function updatePendingCopy(accessState) {
            if (!messageElement || !noteElement) {
              return;
            }

            if (accessState === "reauth_required") {
              messageElement.textContent = "Reconnecting session";
              noteElement.textContent =
                "This browser is known but needs to refresh its device session. Leave this page open.";
              return;
            }

            if (accessState === "auth_mismatch") {
              messageElement.textContent = "Authentication mismatch";
              noteElement.textContent =
                "This browser no longer matches the current device secret. Reconnect it from the active browser context or ask an admin for help.";
              return;
            }

            if (accessState === "blocked_by_other_client") {
              messageElement.textContent = "This browser is not the active one";
              noteElement.textContent =
                "Another browser is currently active for this device. Ask an admin to switch activation if needed.";
              return;
            }

            if (accessState === "revoked") {
              messageElement.textContent = "Access revoked";
              noteElement.textContent =
                "This device no longer has access. Please contact an administrator.";
              return;
            }

            if (currentDeviceStatus !== approvedDeviceStatus) {
              messageElement.textContent = "Access pending";
              noteElement.textContent =
                "This device is waiting for admin approval. Leave this page open.";
              return;
            }

            if (currentIsActivatable) {
              messageElement.textContent = "Waiting for activation";
              noteElement.textContent =
                "This browser is ready. Ask an admin to activate it for this device.";
              return;
            }

            if (currentHasCurrentAuthentication) {
              messageElement.textContent = "Waiting for activation";
              noteElement.textContent =
                "This browser is authenticated. Keep this page open while an admin activates it.";
              return;
            }

            messageElement.textContent = "Preparing activation";
            noteElement.textContent =
              "This browser is establishing access in the background. Leave this page open.";
          }

          function shouldAttemptAuth(accessState) {
            if (authRetryBlocked) {
              return false;
            }

            if (accessState === "reauth_required") {
              return currentCanAttemptReauth === true;
            }

            if (accessState === "pending_activation") {
              return currentCanAttemptBootstrapAuth === true;
            }

            return false;
          }

          async function checkPendingState() {
            if (isChecking) {
              return;
            }

            isChecking = true;

            try {
              if (<%= shouldBootstrap ? "true" : "false" %> && shouldAttemptAuth(lastSeenAccessState)) {
                const secretCandidate = readDeviceSecretCandidate(deviceCode);
                const authResult = await requestBootstrap(secretCandidate.secret);

                if (authResult.ok) {
                  if (secretCandidate.source === "legacy") {
                    persistScopedDeviceSecret(deviceCode, secretCandidate.secret);
                  }
                  currentHasCurrentAuthentication = true;
                  currentHasValidSession = true;
                  authRetryBlocked = false;
                } else if (
                  authResult.status === 401 ||
                  authResult.payload?.status === "unauthorized" ||
                  authResult.payload?.accessState === "auth_mismatch"
                ) {
                  authRetryBlocked = true;
                }
              }

              const statusPayload = await requestStatus();

              if (!statusPayload || typeof statusPayload.accessState !== "string") {
                return;
              }

              currentDeviceStatus = statusPayload.status || currentDeviceStatus;
              currentHasCurrentAuthentication =
                statusPayload.hasCurrentAuthentication === true;
              currentHasValidSession = statusPayload.hasValidSession === true;
              const previousAccessState = lastSeenAccessState;
              currentIsActivatable = statusPayload.isActivatable === true;
              currentCanAttemptBootstrapAuth =
                statusPayload.canAttemptBootstrapAuth === true;
              currentCanAttemptReauth = statusPayload.canAttemptReauth === true;
              lastSeenAccessState = statusPayload.accessState;
              updatePendingCopy(statusPayload.accessState);

              if (
                statusPayload.accessState === "active_authorized" &&
                statusPayload.authorized === true
              ) {
                window.location.reload();
                return;
              }

              if (
                statusPayload.accessState === "revoked" ||
                statusPayload.status === "unknown"
              ) {
                window.location.reload();
                return;
              }

              if (statusPayload.accessState !== previousAccessState) {
                window.location.reload();
                return;
              }
            } catch (error) {
              console.error(error);
            } finally {
              isChecking = false;
            }
          }

          try {
            updatePendingCopy(lastSeenAccessState || currentClientState);
            await checkPendingState();
            window.setInterval(checkPendingState, pollIntervalMs);
          } catch (error) {
            console.error(error);
          }
        })();
      </script>
    <% } %>
  </body>
</html>
