<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/styles/main.css">
  </head>
  <body class="pending-page">
    <main class="pending-wrap">
      <p>Device</p>
      <p><code><%= deviceCode %></code></p>
      <% if (clientState === "pending" && clientId) { %>
        <p>Client ID</p>
        <p><code><%= clientId %></code></p>
      <% } %>
      <p id="device-state-message"><%= message %></p>
      <p class="pending-note" id="device-state-note"><%= note || "" %></p>
    </main>
    <% if (shouldPoll) { %>
      <script>
        (async () => {
          const currentClientState = <%- JSON.stringify(clientState) %>;
          const approvedDeviceStatus = "approved";
          const initialDeviceStatus = <%- JSON.stringify(deviceStatus || null) %>;
          const storageKey = "mydashmaster-device-secret";
          const pollIntervalMs = <%- JSON.stringify(devicePollIntervalMs) %>;
          const initialIsAuthenticated = <%- JSON.stringify(Boolean(isAuthenticated)) %>;
          const initialIsActivatable = <%- JSON.stringify(Boolean(isActivatable)) %>;
          let isChecking = false;
          let currentDeviceStatus = initialDeviceStatus;
          let currentIsAuthenticated = initialIsAuthenticated;
          let currentIsActivatable = initialIsActivatable;
          const messageElement = document.getElementById("device-state-message");
          const noteElement = document.getElementById("device-state-note");

          function createDeviceSecret() {
            const bytes = new Uint8Array(32);
            window.crypto.getRandomValues(bytes);
            return Array.from(bytes, (byte) =>
              byte.toString(16).padStart(2, "0")
            ).join("");
          }

          function getDeviceSecret() {
            let deviceSecret = window.localStorage.getItem(storageKey);

            if (!deviceSecret) {
              deviceSecret = createDeviceSecret();
              window.localStorage.setItem(storageKey, deviceSecret);
            }

            return deviceSecret;
          }

          async function requestBootstrap(deviceSecret) {
            const response = await window.fetch("/api/device/<%= deviceCode %>/auth", {
              body: JSON.stringify({ deviceSecret }),
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/json"
              },
              method: "POST"
            });
            let payload = null;

            try {
              payload = await response.json();
            } catch (error) {
              payload = null;
            }

            return {
              ok: response.ok,
              payload
            };
          }

          async function requestStatus() {
            const response = await window.fetch("/api/device/<%= deviceCode %>/status", {
              cache: "no-store",
              credentials: "same-origin"
            });

            return response.json();
          }

          function updatePendingCopy() {
            if (!messageElement || !noteElement || currentClientState !== "pending") {
              return;
            }

            if (currentDeviceStatus !== approvedDeviceStatus) {
              messageElement.textContent = "Access pending";
              noteElement.textContent =
                "This device is waiting for admin approval. Leave this page open.";
              return;
            }

            if (currentIsActivatable) {
              messageElement.textContent = "Waiting for activation";
              noteElement.textContent =
                "This browser is ready. Ask an admin to activate it for this device.";
              return;
            }

            if (currentIsAuthenticated) {
              messageElement.textContent = "Waiting for activation";
              noteElement.textContent =
                "This browser is authenticated. Keep this page open while an admin activates it.";
              return;
            }

            messageElement.textContent = "Preparing activation";
            noteElement.textContent =
              "This browser is establishing access in the background. Leave this page open.";
          }

          async function checkPendingState() {
            if (isChecking) {
              return;
            }

            isChecking = true;

            try {
              if (<%= shouldBootstrap ? "true" : "false" %> && !currentIsAuthenticated) {
                const deviceSecret = getDeviceSecret();
                const authResult = await requestBootstrap(deviceSecret);

                if (authResult.ok) {
                  currentIsAuthenticated = true;
                }
              }

              const statusPayload = await requestStatus();

              if (!statusPayload || typeof statusPayload.clientState !== "string") {
                return;
              }

              currentDeviceStatus = statusPayload.status || currentDeviceStatus;
              currentIsAuthenticated = statusPayload.isAuthenticated === true;
              currentIsActivatable = statusPayload.isActivatable === true;
              updatePendingCopy();

              if (statusPayload.clientState === "active" && statusPayload.authorized === true) {
                window.location.reload();
                return;
              }

              if (
                statusPayload.clientState === "revoked" ||
                statusPayload.clientState === "unknown"
              ) {
                window.location.reload();
                return;
              }

              if (statusPayload.clientState !== currentClientState) {
                window.location.reload();
              }
            } catch (error) {
              console.error(error);
            } finally {
              isChecking = false;
            }
          }

          try {
            updatePendingCopy();
            await checkPendingState();
            window.setInterval(checkPendingState, pollIntervalMs);
          } catch (error) {
            console.error(error);
          }
        })();
      </script>
    <% } %>
  </body>
</html>
