<!doctype html>
<html lang="en" class="device-page">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/styles/main.css">
  </head>
  <body class="device-page">
    <% if (options.showHeader) { %>
      <header class="site-header">
        <div class="container">
          <a class="brand" href="/">MyDashmaster</a>
        </div>
      </header>
    <% } %>

    <main class="device-main<%= options.showHeader ? ' container' : '' %>">
      <section class="<%= options.showHeader ? 'panel' : 'device-panel' %>">
        <% if (options.showStatus) { %>
          <h1>Device active</h1>
        <% } %>

        <%- include("../partials/device-layout-root", {
          hasBoxes,
          layoutExists,
          layoutId,
          options,
          renderTree
        }) %>
      </section>
    </main>
    <script>
      (() => {
        const currentState = {
          accessState: <%- JSON.stringify(accessState || "active_authorized") %>,
          authorized: true,
          deviceCode: <%- JSON.stringify(deviceCode) %>,
          layoutId: <%- JSON.stringify(layoutId || null) %>,
          reloadVersion: <%- JSON.stringify(reloadVersion || 0) %>,
          status: "approved"
        };
        const pollIntervalMs = <%- JSON.stringify(devicePollIntervalMs) %>;
        let fragmentFailureCount = 0;
        let isUpdatingLayout = false;
        let isReauthInProgress = false;
        let reauthRetryBlocked = false;
        let softFailureCount = 0;
        let latestExpectedLayoutId = currentState.layoutId;

        function normalizeLayoutId(value) {
          return typeof value === "string" && value !== "" ? value : null;
        }

        function initializeLayoutRoot(layoutRoot) {
          return layoutRoot;
        }

        function getLayoutRoot() {
          return document.getElementById("device-layout-root");
        }

        function getScopedDeviceSecretKey(currentDeviceCode) {
          return `mydashmaster-device-secret:${currentDeviceCode}`;
        }

        function getLegacyDeviceSecretKey() {
          return "mydashmaster-device-secret";
        }

        function persistScopedDeviceSecret(currentDeviceCode, deviceSecret) {
          window.localStorage.setItem(
            getScopedDeviceSecretKey(currentDeviceCode),
            deviceSecret
          );
        }

        function readDeviceSecretCandidate(currentDeviceCode) {
          const scopedDeviceSecret = window.localStorage.getItem(
            getScopedDeviceSecretKey(currentDeviceCode)
          );

          if (scopedDeviceSecret) {
            return {
              secret: scopedDeviceSecret,
              source: "scoped"
            };
          }

          const legacyDeviceSecret = window.localStorage.getItem(
            getLegacyDeviceSecretKey()
          );

          if (legacyDeviceSecret) {
            return {
              secret: legacyDeviceSecret,
              source: "legacy"
            };
          }

          return null;
        }

        function isHardAccessState(accessState) {
          return (
            accessState === "revoked" ||
            accessState === "auth_mismatch" ||
            accessState === "blocked_by_other_client"
          );
        }

        async function requestReauth(deviceSecret) {
          const response = await window.fetch(
            `/api/device/${encodeURIComponent(currentState.deviceCode)}/auth`,
            {
              body: JSON.stringify({ deviceSecret }),
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/json"
              },
              method: "POST"
            }
          );
          let payload = null;

          try {
            payload = await response.json();
          } catch (error) {
            payload = null;
          }

          return {
            ok: response.ok,
            payload,
            status: response.status
          };
        }

        async function fetchLayoutFragment() {
          const response = await window.fetch(
            `/api/device/${encodeURIComponent(currentState.deviceCode)}/layout-fragment`,
            {
              cache: "no-store",
              credentials: "same-origin"
            }
          );

          if (response.status === 401 || response.status === 403 || response.status === 404) {
            const error = new Error("Layout fragment request is no longer authorized");
            error.code = "LAYOUT_UNAUTHORIZED";
            throw error;
          }

          if (!response.ok) {
            throw new Error(`Layout fragment request failed with ${response.status}`);
          }

          const fragmentHtml = await response.text();
          const parser = new window.DOMParser();
          const fragmentDocument = parser.parseFromString(fragmentHtml, "text/html");
          const nextLayoutRoot = fragmentDocument.getElementById("device-layout-root");
          const headerLayoutId = normalizeLayoutId(response.headers.get("x-layout-id"));
          const fragmentLayoutId = nextLayoutRoot
            ? normalizeLayoutId(nextLayoutRoot.getAttribute("data-layout-id"))
            : null;

          if (!nextLayoutRoot) {
            throw new Error("Layout fragment root is missing");
          }

          if (headerLayoutId !== fragmentLayoutId) {
            throw new Error("Layout fragment metadata does not match");
          }

          return {
            layoutId: fragmentLayoutId,
            layoutRoot: nextLayoutRoot
          };
        }

        async function updateLayoutFragment(nextLayoutId) {
          if (isUpdatingLayout) {
            latestExpectedLayoutId = nextLayoutId;
            return;
          }

          isUpdatingLayout = true;
          latestExpectedLayoutId = nextLayoutId;

          const currentLayoutRoot = getLayoutRoot();

          if (currentLayoutRoot) {
            currentLayoutRoot.classList.add("device-layout-root--updating");
          }

          let shouldContinueUpdate = false;

          try {
            const requestedLayoutId = latestExpectedLayoutId;
            const { layoutId: fragmentLayoutId, layoutRoot } =
              await fetchLayoutFragment();

            if (
              requestedLayoutId !== latestExpectedLayoutId ||
              fragmentLayoutId !== latestExpectedLayoutId
            ) {
              shouldContinueUpdate = currentState.layoutId !== latestExpectedLayoutId;
              return;
            }

            const activeLayoutRoot = getLayoutRoot();

            if (!activeLayoutRoot) {
              throw new Error("Current layout root is missing");
            }

            initializeLayoutRoot(layoutRoot);
            activeLayoutRoot.replaceWith(layoutRoot);

            currentState.layoutId = fragmentLayoutId;
            fragmentFailureCount = 0;
          } catch (error) {
            if (error.code === "LAYOUT_UNAUTHORIZED") {
              window.location.reload();
              return;
            }

            fragmentFailureCount += 1;

            if (fragmentFailureCount >= 3) {
              window.location.reload();
              return;
            }

            console.error(error);
          } finally {
            const activeLayoutRoot = getLayoutRoot();

            if (activeLayoutRoot) {
              activeLayoutRoot.classList.remove("device-layout-root--updating");
            }

            isUpdatingLayout = false;

            if (shouldContinueUpdate) {
              window.queueMicrotask(() => {
                updateLayoutFragment(latestExpectedLayoutId).catch((error) => {
                  console.error(error);
                });
              });
            }
          }
        }

        async function attemptSilentReauth() {
          if (reauthRetryBlocked || isReauthInProgress) {
            return "soft_failure";
          }

          const secretCandidate = readDeviceSecretCandidate(currentState.deviceCode);

          if (!secretCandidate?.secret) {
            return "soft_failure";
          }

          isReauthInProgress = true;

          try {
            const authResult = await requestReauth(secretCandidate.secret);

            if (authResult.ok) {
              if (secretCandidate.source === "legacy") {
                persistScopedDeviceSecret(currentState.deviceCode, secretCandidate.secret);
              }
              reauthRetryBlocked = false;
              softFailureCount = 0;
              return "reauth_success";
            }

            if (
              authResult.status === 401 ||
              authResult.payload?.status === "unauthorized" ||
              authResult.payload?.accessState === "auth_mismatch"
            ) {
              reauthRetryBlocked = true;
              return "hard_failure";
            }

            return "soft_failure";
          } finally {
            isReauthInProgress = false;
          }
        }

        function resetSoftFailureState() {
          softFailureCount = 0;
        }

        async function pollDeviceStatus() {
          try {
            const response = await window.fetch(
              `/api/device/${encodeURIComponent(currentState.deviceCode)}/status`,
              {
                cache: "no-store",
                credentials: "same-origin"
              }
            );
            const payload = await response.json();

            if (!payload || payload.status !== currentState.status) {
              window.location.reload();
              return;
            }

            if (payload.reloadVersion !== currentState.reloadVersion) {
              window.location.reload();
              return;
            }

            currentState.accessState = payload.accessState;

            if (
              payload.accessState === "active_authorized" &&
              payload.authorized === true
            ) {
              resetSoftFailureState();

              if (payload.layoutId !== currentState.layoutId) {
                await updateLayoutFragment(payload.layoutId);
              }

              return;
            }

            if (isHardAccessState(payload.accessState)) {
              window.location.reload();
              return;
            }

            if (payload.accessState === "reauth_required") {
              softFailureCount += 1;
              const reauthOutcome = await attemptSilentReauth();

              if (reauthOutcome === "hard_failure") {
                window.location.reload();
                return;
              }

              if (reauthOutcome === "reauth_success") {
                return;
              }

              if (softFailureCount >= 2) {
                window.location.reload();
                return;
              }

              return;
            }

            if (payload.accessState === "pending_activation") {
              softFailureCount += 1;

              if (softFailureCount >= 2) {
                window.location.reload();
              }

              return;
            }

            window.location.reload();
          } catch (error) {
            console.error(error);
          }
        }

        window.setInterval(pollDeviceStatus, pollIntervalMs);
      })();
    </script>
  </body>
</html>
