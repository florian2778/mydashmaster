<%- include("../partials/header") %>

<section class="panel">
  <header class="admin-layouts-header">
    <div>
      <p class="admin-layouts-eyebrow">Admin</p>
      <h1><%= heading %></h1>
      <p class="admin-layouts-subtitle">
        Registered devices, their status, and activation controls.
      </p>
    </div>
    <a class="admin-secondary-link" href="/admin">Back to admin</a>
  </header>

  <section class="admin-device-create">
    <div>
      <h2>Create Device</h2>
      <p class="admin-layouts-subtitle">
        Generate a new pending device code for onboarding.
      </p>
    </div>

    <form class="admin-device-create-form" action="/admin/devices" method="post">
      <label>
        <span>Layout</span>
        <select name="layoutId">
          <option value="">No layout assigned</option>
          <% layouts.forEach((layout) => { %>
            <option value="<%= layout.layoutId %>"><%= layout.displayName %></option>
          <% }) %>
        </select>
      </label>
      <button class="admin-action-button" type="submit">Create Device</button>
    </form>
  </section>

  <% if (devices.length === 0) { %>
    <p>No device JSON files found in <code>data/devices/</code>.</p>
  <% } else { %>
    <section class="device-overview-list">
      <% devices.forEach((device) => { %>
        <article
          class="device-overview-card device-overview-card--<%= device.overviewState %>"
          data-device-code="<%= device.deviceCode %>"
          data-last-connected-at="<%= device.lastConnectedAt || "" %>"
          data-last-status-at="<%= device.lastStatusAt || "" %>"
          data-overview-state="<%= device.overviewState %>"
        >
          <div class="device-overview-card-head">
            <div class="device-overview-card-titlewrap">
              <h2 class="device-overview-card-title"><%= device.displayTitle %></h2>
              <a class="device-overview-device-link" href="<%= device.devicePublicUrl %>">
                <code><%= device.deviceCode %></code>
              </a>
            </div>
            <a
              aria-label="Edit device <%= device.deviceCode %>"
              class="device-overview-edit-link"
              href="<%= device.detailUrl %>"
              title="Open device detail"
            >&#9998;</a>
          </div>

          <div class="device-overview-statusline">
            <div class="device-overview-status-block">
              <p class="device-overview-status-label">Overall Status</p>
              <div class="device-overview-status-main">
                <span
                  class="device-overview-status-bubble device-overview-status-bubble--<%= device.overviewState %>"
                  aria-hidden="true"
                ></span>
                <span
                  class="device-overview-status-text"
                  data-role="status-text"
                ><%= device.overviewStateLabel %></span>
              </div>
            </div>
            <div class="device-overview-secondary">
              <p class="device-overview-secondary-label" data-role="secondary-label"><%= device.displaySecondaryLabel %></p>
              <p class="device-overview-secondary-value" data-role="secondary-value"><%= device.displaySecondaryValue %></p>
            </div>
          </div>

          <div class="device-overview-details">
            <p class="device-overview-layout">Layout: <strong><%= device.displayLayoutName %></strong></p>
          </div>
        </article>
      <% }) %>
    </section>
  <% } %>
</section>

<% if (devices.length > 0) { %>
  <script>
    (() => {
      const pollIntervalMs = <%- JSON.stringify(15000) %>;
      const cards = Array.from(document.querySelectorAll("[data-device-code]"));

      if (cards.length === 0) {
        return;
      }

      const cardByDeviceCode = new Map(
        cards.map((card) => [card.getAttribute("data-device-code"), card])
      );

      function applyCardUpdate(card, device) {
        const previousState = card.dataset.overviewState;
        const nextState = device.overviewState;

        if (previousState && previousState !== nextState) {
          card.classList.remove(`device-overview-card--${previousState}`);
        }

        card.dataset.overviewState = nextState;
        card.dataset.lastConnectedAt = device.lastConnectedAt || "";
        card.dataset.lastStatusAt = device.lastStatusAt || "";
        card.classList.add(`device-overview-card--${nextState}`);

        const bubble = card.querySelector(".device-overview-status-bubble");
        if (bubble) {
          if (previousState && previousState !== nextState) {
            bubble.classList.remove(`device-overview-status-bubble--${previousState}`);
          }

          bubble.classList.add(`device-overview-status-bubble--${nextState}`);
        }

        const statusText = card.querySelector('[data-role="status-text"]');
        if (statusText) {
          statusText.textContent = device.overviewStateLabel;
        }

        const secondaryLabel = card.querySelector('[data-role="secondary-label"]');
        const secondaryValue = card.querySelector('[data-role="secondary-value"]');
        if (secondaryLabel && secondaryValue) {
          secondaryLabel.textContent = device.displaySecondaryLabel;
          secondaryValue.textContent = device.displaySecondaryValue;
        }
      }

      async function refreshOverview() {
        try {
          const response = await fetch("/admin/devices/overview-data", {
            credentials: "same-origin",
            headers: {
              Accept: "application/json"
            }
          });

          if (!response.ok) {
            return;
          }

          const payload = await response.json();

          if (!payload || !Array.isArray(payload.devices)) {
            return;
          }

          payload.devices.forEach((device) => {
            const card = cardByDeviceCode.get(device.deviceCode);

            if (card) {
              applyCardUpdate(card, device);
            }
          });
        } catch (error) {
          console.error("Failed to refresh device overview", error);
        }
      }

      window.setInterval(refreshOverview, pollIntervalMs);
    })();
  </script>
<% } %>

<%- include("../partials/footer") %>
