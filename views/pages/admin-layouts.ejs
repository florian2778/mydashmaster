<%- include("../partials/header") %>

<section class="panel">
  <header class="admin-layouts-header">
    <div>
      <h1><%= heading %></h1>
      <p class="admin-layouts-subtitle">Existing layouts with validation state and structure preview.</p>
    </div>
    <div class="admin-layout-detail-actions">
      <a class="admin-secondary-link" href="/admin">Back to admin</a>
      <form action="/admin/layouts/create" method="post">
        <button class="admin-action-button" type="submit">New layout</button>
      </form>
    </div>
  </header>

  <% if (layouts.length === 0) { %>
    <p>No layout JSON files found in <code>data/layouts/</code>.</p>
  <% } else { %>
    <section class="layout-overview-list">
      <% layouts.forEach((layout) => { %>
        <a class="layout-overview-card" href="/admin/layouts/<%= encodeURIComponent(layout.layoutId) %>">
          <div class="layout-preview-shell<%= layout.isNeutralPreview ? ' layout-preview-shell--neutral' : '' %><%= layout.previewSummary.hasOverflow ? ' layout-preview-shell--overflow' : '' %>">
            <% if (layout.previewSummary.hasOverflow) { %>
              <span class="layout-preview-flag">Overflow</span>
            <% } %>
            <div class="layout-preview-frame">
              <div class="layout-preview">
            <%- include("../partials/layout-preview-node", {
              node: layout.previewTree
            }) %>
              </div>
            </div>
          </div>

          <div class="layout-overview-meta">
            <h2><%= layout.description || layout.layoutId %></h2>
            <% if (layout.description) { %>
              <p class="admin-layouts-subtitle"><code><%= layout.layoutId %></code></p>
            <% } %>

            <div class="layout-overview-facts">
              <span class="layout-status layout-status--<%= layout.status %>">
                <%= layout.status %>
              </span>
              <span><%= layout.boxCount %> <%= layout.boxCount === 1 ? "box" : "boxes" %></span>
              <% if (layout.previewSummary.invalidBoxCount > 0) { %>
                <span class="layout-edge-indicator layout-edge-indicator--error">
                  <%= layout.previewSummary.invalidBoxCount %> invalid ref<%= layout.previewSummary.invalidBoxCount === 1 ? "" : "s" %>
                </span>
              <% } else if (layout.previewSummary.hasOverflow) { %>
                <span class="layout-edge-indicator">preview overflow</span>
              <% } %>
            </div>
          </div>
        </a>
      <% }) %>
    </section>
  <% } %>
</section>

<%- include("../partials/footer") %>
