<%- include("../partials/header") %>

<section class="panel admin-layout-detail-panel">
  <header class="admin-layout-detail-header">
    <div class="admin-layout-detail-heading">
      <div class="admin-layout-detail-titleline">
        <% if (editMode) { %>
          <input
            id="description"
            class="admin-layout-detail-title-input"
            name="description"
            type="text"
            value="<%= descriptionValue %>"
            placeholder="<%= layout.layoutId %>"
            form="layout-editor-form"
          >
        <% } else { %>
          <h1><%= (layout.layout && layout.layout.description) || layout.layoutId %></h1>
        <% } %>
        <span class="layout-status layout-status--<%= validationStatus %>">
          <%= validationStatus %>
        </span>
      </div>
      <p class="admin-layout-detail-version">layoutId: <strong><%= layout.layoutId %></strong></p>
      <p class="admin-layout-detail-version">layoutVersion: <strong><%= versionDisplay %></strong></p>
      <% if (versionNote) { %>
        <p class="admin-layout-detail-migration-note"><%= versionNote %></p>
      <% } %>
    </div>

    <div class="admin-layout-detail-actions">
      <% if (editMode) { %>
        <a class="admin-secondary-link" href="/admin/layouts/<%= encodeURIComponent(layout.layoutId) %>">Back to read-only</a>
      <% } else { %>
        <a class="admin-secondary-link" href="/admin/layouts">Back to layouts</a>
        <form action="/admin/layouts/<%= encodeURIComponent(layout.layoutId) %>/duplicate" method="post">
          <button class="admin-action-button admin-action-button--secondary" type="submit">Duplicate</button>
        </form>
        <form action="/admin/layouts/<%= encodeURIComponent(layout.layoutId) %>/delete" method="post">
          <button class="admin-action-button admin-action-button--delete" type="submit">Delete</button>
        </form>
        <a class="admin-action-button" href="/admin/layouts/<%= encodeURIComponent(layout.layoutId) %>?mode=edit">Edit</a>
      <% } %>
    </div>
  </header>

  <section class="admin-layout-detail-section">
    <h2>Validation</h2>

    <% if (validationStatus === "valid") { %>
      <p class="admin-layout-detail-empty">Layout validation passed without warnings.</p>
    <% } else { %>
      <% if (validationErrors.length > 0) { %>
        <div class="admin-layout-validation admin-layout-validation--error">
          <strong>Errors</strong>
          <ul class="admin-layout-validation-list">
            <% validationErrors.forEach((message) => { %>
              <li><%= message %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (validationWarnings.length > 0) { %>
        <div class="admin-layout-validation admin-layout-validation--warning">
          <strong>Warnings</strong>
          <ul class="admin-layout-validation-list">
            <% validationWarnings.forEach((message) => { %>
              <li><%= message %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>
    <% } %>
  </section>

  <section class="admin-layout-detail-section">
    <h2>Used by devices</h2>

    <% if (layoutUsageDevices.length === 0) { %>
      <p class="admin-layout-detail-empty">No device currently uses this layout.</p>
    <% } else { %>
      <div class="admin-layout-usage-list">
        <% layoutUsageDevices.forEach((device) => { %>
          <article class="admin-layout-usage-card">
            <strong><%= device.deviceCode %></strong>
            <% if (device.description) { %>
              <span><strong>Description:</strong> <%= device.description %></span>
            <% } %>
            <span class="admin-layout-usage-status"><strong>Status:</strong> <%= device.status %></span>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>

  <section class="admin-layout-detail-section admin-api-access-section">
    <div class="admin-layout-detail-section-head">
      <h2>API Access</h2>
    </div>
    <p class="admin-layout-detail-empty">Manage which existing API keys may access this layout. Secret key values are never shown here.</p>

    <% if (apiAccess.configErrorMessage) { %>
      <p class="admin-form-error"><%= apiAccess.configErrorMessage %></p>
    <% } %>
    <% if (apiAccess.errorMessage) { %>
      <p class="admin-form-error"><%= apiAccess.errorMessage %></p>
    <% } %>
    <% if (apiAccess.successMessage) { %>
      <p class="admin-form-success"><%= apiAccess.successMessage %></p>
    <% } %>

    <% if (apiAccess.assignedApiKeys.length === 0) { %>
      <p class="admin-layout-detail-empty">No API key currently has access to this layout.</p>
    <% } else { %>
      <div class="admin-api-access-list">
        <% apiAccess.assignedApiKeys.forEach((apiKey) => { %>
          <article class="admin-api-access-card">
            <div>
              <strong><%= apiKey.name %></strong>
              <span><%= apiKey.mode %></span>
            </div>
            <form action="/admin/layouts/<%= encodeURIComponent(layout.layoutId) %>/api-access" method="post">
              <input type="hidden" name="intent" value="remove">
              <input type="hidden" name="apiKeyName" value="<%= apiKey.name %>">
              <button class="admin-action-button admin-action-button--secondary" type="submit">Remove</button>
            </form>
          </article>
        <% }) %>
      </div>
    <% } %>

    <% if (!apiAccess.configErrorMessage) { %>
      <form class="admin-api-access-form" action="/admin/layouts/<%= encodeURIComponent(layout.layoutId) %>/api-access" method="post">
        <input type="hidden" name="intent" value="add">
        <label>
          <span>Add API key</span>
          <select name="apiKeyName" <%= apiAccess.availableApiKeys.length === 0 ? "disabled" : "" %>>
            <% if (apiAccess.availableApiKeys.length === 0) { %>
              <option value="">No available API keys</option>
            <% } else { %>
              <% apiAccess.availableApiKeys.forEach((apiKey) => { %>
                <option value="<%= apiKey.name %>"><%= apiKey.name %> (<%= apiKey.mode %>)</option>
              <% }) %>
            <% } %>
          </select>
        </label>
        <button class="admin-action-button" type="submit" <%= apiAccess.availableApiKeys.length === 0 ? "disabled" : "" %>>Add</button>
      </form>
    <% } %>
  </section>

  <section class="admin-layout-detail-section">
    <div class="admin-layout-detail-section-head">
      <h2>Configuration</h2>
      <% if (editMode) { %>
        <span class="admin-layout-mode-indicator">Edit mode</span>
      <% } else { %>
        <span class="admin-layout-mode-indicator admin-layout-mode-indicator--readonly">Read-only</span>
      <% } %>
    </div>

    <% if (editMode) { %>
      <form
        id="layout-editor-form"
        action="/admin/layouts/<%= encodeURIComponent(layout.layoutId) %>"
        method="post"
        class="admin-layout-editor-form"
      >
        <label class="admin-layout-editor-label" for="jsonContent">Layout JSON</label>
        <textarea id="jsonContent" name="jsonContent" class="admin-layout-editor"><%= draftJsonContent %></textarea>
        <div class="admin-layout-editor-actions">
          <button class="admin-action-button admin-action-button--secondary" type="submit" name="intent" value="validate">Validate</button>
          <button class="admin-action-button" type="submit" name="intent" value="save">Save</button>
          <button class="admin-action-button admin-action-button--secondary" type="submit" name="intent" value="cancel">Cancel</button>
        </div>
      </form>
    <% } else { %>
      <pre class="admin-layout-config"><%= draftJsonContent %></pre>
    <% } %>
  </section>
</section>

<%- include("../partials/footer") %>
