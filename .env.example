PORT=3000
DEVICE_POLL_INTERVAL_MS=10000

# Docker / Traefik deployment
MYDASHMASTER_HOST=mydashmaster.example.com
# Shared external Docker network that Traefik is attached to on ion01
TRAEFIK_NETWORK=proxy
TRAEFIK_CERTRESOLVER=letsencrypt

# Device session signing
MYDASHMASTER_SESSION_SECRET=replace-with-a-long-random-device-session-secret

# Admin login
ADMIN_USERNAME=admin
# SHA-256 hash of the admin password
ADMIN_PASSWORD_HASH=replace-with-sha256-password-hash
ADMIN_SESSION_SECRET=replace-with-a-long-random-admin-session-secret
